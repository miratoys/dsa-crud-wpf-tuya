<Window x:Class="Midterms.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.Background>
            <RadialGradientBrush>
                <GradientStop Color="#FFAFA0E6" Offset="1"/>
                <GradientStop Color="#FFF5BBF0" Offset="0"/>
            </RadialGradientBrush>
        </Grid.Background>
        <DataGrid Name="cart" ItemsSource="{Binding shoppings}" AutoGenerateColumns="False"  Margin="10,46,410,217" >
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="30"/>
                <DataGridTextColumn Header="NAME" Binding="{Binding NAME}" Width="70"/>
                <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding DESCRIPTION}" Width="110"/>
                <DataGridTextColumn Header="PRICE" Binding="{Binding PRICE}" Width="70"/>
                <DataGridTextColumn Header=" " Width="*" />
            </DataGrid.Columns>
        </DataGrid>
        <TextBlock HorizontalAlignment="Left" Height="30" Margin="29,23,0,0" TextWrapping="Wrap" Text="Available Products Section" VerticalAlignment="Top" Width="370" FontSize="12" FontFamily="Goudy Stout"/>
        <TextBlock HorizontalAlignment="Left" Height="30" Margin="451,23,0,0" TextWrapping="Wrap" Text="Shopping Cart Section" VerticalAlignment="Top" Width="370" FontSize="12" FontFamily="Goudy Stout"/>
        <DataGrid x:Name="Addcart" ItemsSource="{Binding Shoppings}" AutoGenerateColumns="False"  Margin="405,46,10,217" >
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="30"/>
                <DataGridTextColumn Header="NAME" Binding="{Binding NAME}" Width="70"/>
                <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding DESCRIPTION}" Width="110"/>
                <DataGridTextColumn Header="PRICE" Binding="{Binding PRICE}" Width="70"/>
                <DataGridTextColumn Header=" " Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <Button Content="Remove" HorizontalAlignment="Left" Height="27" Margin="646,247,0,0" VerticalAlignment="Top" Width="108" Background="#FF5478E8" Click="RemoveButton_Click" RenderTransformOrigin="0.039,1.076"/>
        <Button Content="Add to Cart" HorizontalAlignment="Left" Height="27" Margin="451,247,0,0" VerticalAlignment="Top" Width="110" Background="#FF5478E8" Click="UpdateButton_Click" RenderTransformOrigin="0.58,-1.008"/>
        <Button Content="Clear" HorizontalAlignment="Left" Height="26" Margin="282,388,0,0" VerticalAlignment="Top" Width="108" Background="#FF5478E8" Click="ClearButton_Click"/>
        <Button Content="Add" HorizontalAlignment="Left" Height="28" Margin="122,386,0,0" VerticalAlignment="Top" Width="108" Background="#FF5478E8" Click="AddBtn_Click" RenderTransformOrigin="-0.211,0.382"/>

        <TextBox Name="Amount" HorizontalAlignment="Left" Height="26" Margin="200,246,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" TextChanged="Amount_TextChanged" />
        <TextBlock HorizontalAlignment="Left" Height="26" Margin="174,247,0,0" TextWrapping="Wrap" Text="ID" VerticalAlignment="Top" Width="104" FontSize="15"/>

        <TextBox Name="Product" HorizontalAlignment="Left" Height="26" Margin="200,278,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" TextChanged="Product_TextChanged" />
        <TextBlock HorizontalAlignment="Left" Height="26" Margin="156,280,0,0" TextWrapping="Wrap" Text="Name" VerticalAlignment="Top" Width="104" FontSize="15"/>

        <TextBox Name="Details" HorizontalAlignment="Left" Height="26" Margin="200,309,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" TextChanged="Details_TextChanged" />
        <TextBlock HorizontalAlignment="Left" Height="26" Margin="122,310,0,0" TextWrapping="Wrap" Text="Description" VerticalAlignment="Top" Width="104" FontSize="15" RenderTransformOrigin="0.546,0.886"/>

        <TextBox Name="Presyo" HorizontalAlignment="Left" Height="26" Margin="200,343,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" TextChanged="Presyo_TextChanged" />
        <TextBlock HorizontalAlignment="Left" Height="26" Margin="163,344,0,0" TextWrapping="Wrap" Text="Price" VerticalAlignment="Top" Width="104" FontSize="15" RenderTransformOrigin="0.546,0.886"/>













    </Grid>
</Window>
